# .env.example
# Environment Configuration Template
# Copy to .env and customize for your build environment

# Project paths
PROJECT_ROOT=/home/wassim/Bureau/yocto/clean
BUILD_DIR=${PROJECT_ROOT}/build
LAYERS_DIR=${PROJECT_ROOT}/layers
POKY_DIR=${LAYERS_DIR}/poky

# Build configuration
MACHINE=raspberrypi5
DISTRO=poky
IMAGE_NAME=rpi5-minimal

# Parallel build settings (adjust to your system)
# For 4-core: BB_NUMBER_THREADS=4, PARALLEL_MAKE=-j4
# For 8-core: BB_NUMBER_THREADS=8, PARALLEL_MAKE=-j8
# For max: BB_NUMBER_THREADS=-1, PARALLEL_MAKE=-j
BB_NUMBER_THREADS=4
PARALLEL_MAKE=-j4

# Disk space (GB) - for monitoring
MIN_FREE_SPACE=50

# Build verbosity (0=quiet, 1=verbose, 2=very verbose)
BITBAKE_VERBOSE=0

# SD Card device for flashing (CAUTION: check before using!)
SD_CARD_DEVICE=/dev/sda

# WiFi Configuration (for flashing to device)
WIFI_SSID=YourSSID
WIFI_PASSWORD=YourPassword

# SSH Configuration
SSH_USER=root
SSH_HOST=raspberrypi5.local
SSH_PORT=22

# Build cache settings
# Set to 0 to disable caching, 1 to enable (recommended)
USE_SSTATE_CACHE=1
SSTATE_CACHE_PATH=${BUILD_DIR}/sstate-cache

# Network settings
# Set to 1 to use a specific source mirror
USE_SOURCE_MIRROR=0
SOURCE_MIRROR_URL=

# Python interpreter (usually python3)
PYTHON_BIN=python3

# BitBake timeout (seconds)
BITBAKE_TIMEOUT=36000

# Optional: Docker image for isolated builds
# Leave empty to build on host system
# DOCKER_IMAGE=crops/yocto:latest
