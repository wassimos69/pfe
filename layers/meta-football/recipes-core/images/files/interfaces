# /etc/network/interfaces -- minimal headless config for RPi5

auto lo
iface lo inet loopback

auto eth0
iface eth0 inet dhcp

auto end0
iface end0 inet dhcp

# Busybox ifupdown may need explicit wildcard matching for en* names
auto /en*=eth
iface eth inet dhcp

auto wlan0
iface wlan0 inet dhcp
    wpa-conf /etc/wpa_supplicant.conf
